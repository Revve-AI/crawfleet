# =============================================================================
# Required — app will not start without these
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
DATABASE_URL=""                       # Postgres connection string (used by migrations)
ADMIN_EMAILS=""                       # Comma-separated admin emails

# =============================================================================
# Cloudflare — required for dashboard tunnel (not tenant networking)
# =============================================================================
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_API_KEY=""                 # Token with Tunnel Edit, DNS Edit
CLOUDFLARE_ZONE_ID=""
# CLOUDFLARE_DOMAIN=""                # Defaults to BASE_DOMAIN

# =============================================================================
# Tailscale — required for tenant networking (tenants can override per-tenant)
# =============================================================================
TAILSCALE_API_KEY=""                  # API key with device management permissions
TAILSCALE_TAILNET=""                  # Tailnet name (e.g., company.github)
# DASHBOARD_PUBLIC_IP=""              # Auto-detected from GCP metadata if not set

# =============================================================================
# GCP — required for tenant provisioning
# =============================================================================
GCP_PROJECT=""
# GCP_SERVICE_ACCOUNT_KEY=""          # JSON or base64 SA key (falls back to ADC)
# GCP_CREDENTIALS_FILE=""             # Path to SA key file (falls back to ADC)

# =============================================================================
# Hetzner — alternative cloud for tenant provisioning
# =============================================================================
# HETZNER_API_TOKEN=""                  # API token from Hetzner Cloud Console

# =============================================================================
# SSH — required for tenant provisioning
# =============================================================================
VPS_SSH_PUBLIC_KEY=""                  # e.g. ssh-ed25519 AAAA...
# VPS_SSH_KEY_PATH="./data/.ssh/fleet_key"

# =============================================================================
# Optional
# =============================================================================
# BASE_DOMAIN="openclaw.example.com"
# FLEET_TLS="true"
# DATA_DIR="./data"
# OPENCLAW_DEFAULT_GIT_TAG="latest"
# BACKUP_BUCKET=""
# BACKUP_INTERVAL_MIN="15"
