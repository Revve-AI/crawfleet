# =============================================================================
# Required — app will not start without these
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
DATABASE_URL=""                       # Postgres connection string (used by migrations)
ADMIN_EMAILS=""                       # Comma-separated admin emails

# =============================================================================
# Cloudflare — required for tenant provisioning
# =============================================================================
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_API_KEY=""                 # Token with Tunnel Edit, Access Edit, DNS Edit
CLOUDFLARE_ZONE_ID=""
# CLOUDFLARE_DOMAIN=""                # Defaults to BASE_DOMAIN
# CLOUDFLARE_IDP_ID=""                # Google Workspace IdP for Access apps

# =============================================================================
# GCP — required for tenant provisioning
# =============================================================================
GCP_PROJECT=""
# GCP_SERVICE_ACCOUNT_KEY=""          # JSON or base64 SA key (falls back to ADC)
# GCP_CREDENTIALS_FILE=""             # Path to SA key file (falls back to ADC)

# =============================================================================
# SSH — required for tenant provisioning
# =============================================================================
VPS_SSH_PUBLIC_KEY=""                  # e.g. ssh-ed25519 AAAA...
# VPS_SSH_KEY_PATH="./data/.ssh/fleet_key"

# =============================================================================
# Optional
# =============================================================================
# BASE_DOMAIN="openclaw.example.com"
# FLEET_TLS="true"
# DATA_DIR="./data"
# OPENCLAW_DEFAULT_GIT_TAG="latest"
# BACKUP_BUCKET=""
# BACKUP_INTERVAL_MIN="15"
