# Database
DATABASE_URL="file:../data/fleet.db"

# Auth (Cloudflare Access)
SESSION_SECRET=""              # 32+ char random string for iron-session
CLOUDFLARE_TEAM_DOMAIN=""      # e.g., "revve" for revve.cloudflareaccess.com
CF_ACCESS_AUD=""               # audience tag from Cloudflare Access app
CLOUDFLARE_ACCOUNT_ID=""       # Cloudflare account ID for per-tenant Access apps
CLOUDFLARE_IDP_ID=""           # Google Workspace IdP ID for Access app login

# Domain
BASE_DOMAIN="openclaw.example.com"

# OpenClaw Image
OPENCLAW_IMAGE="openclaw/openclaw:latest"

# Data directory
DATA_DIR="./data"

# Provider API Keys (shared, injected per-tenant)
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
GEMINI_API_KEY=""
BRAVE_API_KEY=""
ELEVENLABS_API_KEY=""

# Traefik / TLS
DNS_PROVIDER="cloudflare"
ACME_EMAIL=""
CF_API_EMAIL=""
CF_DNS_API_TOKEN=""

# Deploy Target (populated by /deploy-server, used by /deploy-app)
DEPLOY_INSTANCE=""
DEPLOY_PROJECT=""
DEPLOY_ZONE=""
DEPLOY_HOST=""
DEPLOY_TUNNEL_ID=""
DEPLOY_USER=""
DEPLOY_REGISTRY=""  # e.g. asia-southeast1-docker.pkg.dev/project-id/repo-name
