DEPLOY_PROJECT=""
DEPLOY_ZONE=""
DEPLOY_HOST=""
DEPLOY_TUNNEL_ID=""
DEPLOY_USER=""
DEPLOY_REGISTRY=""  # e.g. asia-southeast1-docker.pkg.dev/project-id/repo-name
