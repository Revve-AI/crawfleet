# =============================================================================
# Supabase (required)
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
DATABASE_URL=""                   # Postgres connection string for migrations

# =============================================================================
# Auth (required)
# =============================================================================
ADMIN_EMAILS=""                   # Comma-separated list of admin emails (first user auto-promoted if empty)

# =============================================================================
# Cloudflare (required for tenant provisioning)
# =============================================================================
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_API_KEY=""             # API token with Tunnel Edit, Access Edit, DNS Edit permissions
CLOUDFLARE_ZONE_ID=""             # DNS zone for tenant subdomains
CLOUDFLARE_DOMAIN=""              # Domain for tunnel routing (may differ from BASE_DOMAIN in dev)
CLOUDFLARE_IDP_ID=""              # Google Workspace IdP ID for Access app login (optional)

# =============================================================================
# Domain
# =============================================================================
BASE_DOMAIN="openclaw.example.com"
FLEET_TLS="true"                  # Whether tenant URLs use https (default: true)

# =============================================================================
# GCP (required for tenant provisioning)
# =============================================================================
GCP_PROJECT=""                    # GCP project ID (enables GCP cloud provider)
# GCP_SERVICE_ACCOUNT_KEY=""      # JSON or base64 SA key (optional — falls back to ADC)
# GCP_CREDENTIALS_FILE=""         # Path to SA key file (optional — falls back to ADC)

# =============================================================================
# SSH (required for tenant provisioning)
# =============================================================================
VPS_SSH_KEY_PATH="./data/.ssh/fleet_key"
VPS_SSH_PUBLIC_KEY=""             # ssh-ed25519 AAAA... crawfleet

# =============================================================================
# OpenClaw
# =============================================================================
OPENCLAW_DEFAULT_GIT_TAG="latest" # Default OpenClaw version for new tenants

# =============================================================================
# Provider API Keys (shared across tenants, overridable per-tenant)
# =============================================================================
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
GEMINI_API_KEY=""
BRAVE_API_KEY=""
ELEVENLABS_API_KEY=""

# =============================================================================
# Data directory
# =============================================================================
DATA_DIR="./data"

# =============================================================================
# Backups (optional — enable by setting BACKUP_BUCKET)
# =============================================================================
# BACKUP_BUCKET=""                # GCS bucket name
# BACKUP_INTERVAL_MIN="15"       # Backup interval in minutes

# =============================================================================
# Deploy Target (populated by /deploy-server, used by scripts/deploy-app.sh)
# =============================================================================
# DEPLOY_INSTANCE=""
# DEPLOY_PROJECT=""
# DEPLOY_ZONE=""
# DEPLOY_HOST=""
# DEPLOY_TUNNEL_ID=""
# DEPLOY_USER=""
# DEPLOY_REGISTRY=""              # e.g. us-central1-docker.pkg.dev/project-id/repo-name
