datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Tenant {
  id              String   @id @default(cuid())
  slug            String   @unique
  displayName     String
  email           String?

  enabled         Boolean  @default(true)
  containerId     String?
  containerStatus String   @default("stopped")
  accessAppId     String?

  image           String?
  envOverrides    String?

  gatewayToken    String

  provider        String   @default("docker") // "docker" | "vps"

  lastHealthCheck  DateTime?
  lastHealthStatus String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  auditLogs       AuditLog[]
  vpsInstance     VpsInstance?
}

model VpsInstance {
  id              String   @id @default(cuid())
  tenantId        String   @unique
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  cloud           String   // "gcp" | "hetzner" | "aws"
  region          String
  instanceId      String
  machineType     String
  externalIp      String?

  tunnelId        String?
  tunnelToken     String?

  gitTag          String?

  sshUser         String   @default("openclaw")
  sshPort         Int      @default(22)

  vmStatus        String   @default("creating") // creating|running|stopped|error|destroying

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model GlobalSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  tenantId  String?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  action    String
  details   String?
  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([createdAt])
}
